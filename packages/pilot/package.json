{
  "name": "pilot",
  "version": "0.1.0",
  "description": "Mobile app testing framework — TypeScript SDK and test runner",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "pilot": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc && npm run build:trace-viewer",
    "build:trace-viewer": "vite build",
    "lint": "eslint src/ --ignore-pattern src/trace-viewer/",
    "knip": "knip",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist/",
    "src/"
  ],
  "keywords": [
    "mobile",
    "testing",
    "android",
    "automation",
    "ui-testing"
  ],
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.12.0",
    "@grpc/proto-loader": "^0.7.13",
    "fflate": "^0.8.2",
    "glob": "^11.0.0",
    "open": "^10.2.0",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@prefresh/vite": "^2.4.12",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "knip": "^5.86.0",
    "preact": "^10.29.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^5.4.21",
    "vite-plugin-singlefile": "^2.3.2",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
