#!/usr/bin/env bash
set -e

CHANGED_FILES=$(git diff --cached --name-only)

# ─── Rust ───
if echo "$CHANGED_FILES" | grep -q '^packages/pilot-core/'; then
  echo "▸ Rust: cargo fmt --check"
  (cd packages/pilot-core && cargo fmt -- --check)
  echo "▸ Rust: cargo clippy"
  (cd packages/pilot-core && cargo clippy -- -D warnings)
  echo "▸ Rust: cargo test"
  (cd packages/pilot-core && cargo test)
fi

# ─── TypeScript SDK ───
if echo "$CHANGED_FILES" | grep -q '^packages/pilot/'; then
  echo "▸ TypeScript: typecheck"
  (cd packages/pilot && npm run typecheck)
  echo "▸ TypeScript: lint"
  (cd packages/pilot && npm run lint)
  echo "▸ TypeScript: test"
  (cd packages/pilot && npm run test)
fi

# ─── Proto ───
if echo "$CHANGED_FILES" | grep -q '^proto/'; then
  if command -v buf &>/dev/null; then
    echo "▸ Proto: buf lint"
    buf lint proto/
  fi
fi

# ─── Test app ───
if echo "$CHANGED_FILES" | grep -q '^test-app/'; then
  echo "▸ Test app: typecheck"
  (cd test-app && npm run typecheck)
  echo "▸ Test app: lint"
  (cd test-app && npm run lint)
  echo "▸ Test app: format check"
  (cd test-app && npm run format:check)
fi

# ─── Android agent ───
if echo "$CHANGED_FILES" | grep -q '^agent/'; then
  echo "▸ Android: ktlintCheck"
  (cd agent && ./gradlew ktlintCheck)
fi
