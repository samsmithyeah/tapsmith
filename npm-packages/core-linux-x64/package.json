{
  "name": "@tapsmith/core-linux-x64",
  "version": "0.1.0",
  "description": "Tapsmith daemon binary for Linux x64",
  "os": ["linux"],
  "cpu": ["x64"],
  "files": ["tapsmith-core"],
  "preferUnplugged": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/samsmithyeah/tapsmith.git",
    "directory": "npm-packages/core-linux-x64"
  },
  "license": "MIT",
  "scripts": {
    "postinstall": "node -e \"try{require('fs').chmodSync('tapsmith-core',0o755)}catch(e){console.warn('tapsmith: chmod failed:',e.message)}\""
  }
}
